<ol class="items-list">
  <li class="item flexrow inventory-header">
    <div class="item-name">이름</div>
    <div class="item-ac" style="flex: 0 0 60px; text-align: center;">AC</div>
    <div class="item-weight" style="flex: 0 0 60px; text-align: center;">칸</div>
    <div class="item-controls">
      <a class="item-control item-create" title="Create armor" data-type="item"><i class="fas fa-plus"></i> 방어구 추가</a>
    </div>
  </li>
  {{#each armor as |item id|}}
    <li class="item flexrow" data-item-id="{{item._id}}">
      <div class="item-name">
        <div class="item-image">
          <a class="rollable" data-roll-type="item">
            <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
          </a>
        </div>
        <div class="armor-info">
          <h4 class="item-name-header">{{item.name}}</h4>
          {{#if item.system.isCumbersome}}<span style="font-size: 0.8em; color: #c9c7b8;">(불편함)</span>{{/if}}
          {{#if item.system.isAccessory}}<span style="font-size: 0.8em; color: #c9c7b8;">(부속)</span>{{/if}}
        </div>
      </div>
      
      {{!-- AC 보너스 표시 --}}
      <div class="item-ac" style="flex: 0 0 60px; text-align: center;">
        +{{item.system.acBonus}}
      </div>

      {{!-- 무게/칸 표시 --}}
      <div class="item-weight" style="flex: 0 0 60px; text-align: center;">
        {{item.system.weight}}
      </div>

      <div class="item-controls">
        <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
        <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
      </div>
    </li>
  {{/each}}
</ol>
