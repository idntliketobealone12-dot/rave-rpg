{{!-- 부상 추가 UI --}}
<div style="padding: 12px; background-color: #d5d5d5; margin-bottom: 12px; border-radius: 6px; border: 1px solid #b8b8b8;">
  <h3 style="margin-top: 0; margin-bottom: 8px; color: #1a1a1a;">부상 추가</h3>
  <div style="display: grid; grid-template-columns: 2fr 1fr auto; gap: 8px; align-items: end;">
    <div>
      <label style="font-weight: bold; display: block; margin-bottom: 4px; color: #1a1a1a;">부상 이름</label>
      <input type="text" id="wound-name" placeholder="예: 팔 골절" style="width: 100%; padding: 4px; box-sizing: border-box; background: #e8e8e8; border: 1px solid #a8a8a8; color: #1a1a1a; border-radius: 3px;"/>
    </div>
    <div>
      <label style="font-weight: bold; display: block; margin-bottom: 4px; color: #1a1a1a;">부상 칸 수</label>
      <input type="number" id="wound-slots" value="1" min="1" style="width: 100%; padding: 4px; box-sizing: border-box; background: #e8e8e8; border: 1px solid #a8a8a8; color: #1a1a1a; border-radius: 3px;"/>
    </div>
    <div>
      <button type="button" class="add-wound-button" style="padding: 6px 12px; cursor: pointer; white-space: nowrap; background: #16a085; color: white; border: none; border-radius: 3px; font-weight: 600;">
        <i class="fas fa-plus"></i> 추가
      </button>
    </div>
  </div>
</div>

{{!-- 부상 목록 --}}
<div style="padding: 12px; background-color: #d5d5d5; margin-bottom: 12px; border-radius: 6px; border: 1px solid #b8b8b8; overflow: hidden;">
  <h3 style="margin-top: 0; margin-bottom: 8px; color: #1a1a1a;">부상 현황</h3>
  <div style="display: grid; grid-template-columns: 1fr; gap: 4px; min-width: 0;">
    {{#each effects as |section|}}
      {{#each section.effects as |effect|}}
        {{#if effect.flags.rave-rpg.isWound}}
          <div style="display: flex; justify-content: space-between; align-items: center; padding: 6px 8px; background-color: #e8e8e8; border-radius: 4px; border-left: 3px solid #e74c3c; color: #1a1a1a; min-width: 0; font-size: 0.9em;">
            <div style="display: flex; align-items: center; gap: 6px; min-width: 0; flex: 1;">
              <img src="{{effect.icon}}" style="width: 20px; height: 20px; border-radius: 3px; flex-shrink: 0;"/>
              <span style="font-weight: 500; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{effect.name}}</span>
            </div>
            <div style="display: flex; align-items: center; gap: 4px; flex-shrink: 0; margin-left: 8px;">
              <span style="color: #333; font-weight: 600; white-space: nowrap;">{{effect.flags.rave-rpg.woundSlots}}칸</span>
              <button class="wound-delete-btn" data-effect-id="{{effect.id}}" style="padding: 2px 4px; background: #e74c3c; color: white; border: none; border-radius: 2px; cursor: pointer; font-size: 0.7em; flex-shrink: 0; display: flex; align-items: center; justify-content: center; width: 20px; height: 20px;">
                <i class="fas fa-trash" style="font-size: 0.9em;"></i>
              </button>
            </div>
          </div>
        {{/if}}
      {{/each}}
    {{/each}}
    {{#unless @root.hasWounds}}
      <div style="padding: 8px; color: #707070; font-style: italic;">부상이 없습니다.</div>
    {{/unless}}
  </div>
</div>

<ol class="items-list effects-list">
  {{#each effects as |section sid|}}
    <li class="items-header flexrow" data-effect-type="{{section.type}}" data-parent-id="{{@root.actor.id}}" >
      <h3 class="item-name effect-name flexrow">{{localize section.label}}</h3>
      <div class="effect-source">{{localize "RAVE.Effect.Source"}}</div>
      <div class="effect-source">{{localize "EFFECT.TabDuration"}}</div>
      <div class="item-controls effect-controls flexrow">
        <a class="effect-control" data-action="create" title="{{localize 'DOCUMENT.Create' type="Effect"}}">
          <i class="fas fa-plus"></i> {{localize "DOCUMENT.New" type="Effect"}}
        </a>
      </div>
    </li>

    <ol class="item-list">
    {{#each section.effects as |effect|}}
      <li class="item effect flexrow" data-effect-id="{{effect.id}}" data-parent-id="{{effect.parent.id}}">
        <div class="item-name effect-name flexrow">
          <img class="item-image" src="{{effect.icon}}"/>
          <h4>{{effect.name}}</h4>
          {{#if effect.flags.rave-rpg.isWound}}
            <span style="margin-left: 8px; font-weight: bold; color: #c41e3a;">+{{effect.flags.rave-rpg.woundSlots}} 칸</span>
          {{/if}}
        </div>
        <div class="effect-source">{{effect.sourceName}}</div>
        <div class="effect-duration">{{effect.duration.label}}</div>
        <div class="item-controls effect-controls flexrow">
          <a class="effect-control" data-action="toggle" title="{{localize 'RAVE.Effect.Toggle'}}">
            <i class="fas {{#if effect.disabled}}fa-check{{else}}fa-times{{/if}}"></i>
          </a>
          <a class="effect-control" data-action="edit" title="{{localize 'DOCUMENT.Update' type="Effect"}}">
            <i class="fas fa-edit"></i>
          </a>
          <a class="effect-control" data-action="delete" title="{{localize 'DOCUMENT.Delete' type="Effect"}}">
            <i class="fas fa-trash"></i>
          </a>
        </div>
      </li>
    {{/each}}
    </ol>
  {{/each}}
</ol>
