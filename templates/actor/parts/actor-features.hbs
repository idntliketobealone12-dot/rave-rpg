<ol class='items-list'>
  <li class='item flexrow items-header'>
    <div class='item-name'>{{localize 'Name'}}</div>
    <div class='item-controls'>
      <a
        class='item-control item-create'
        title='Create item'
        data-type='feature'
      >
        <i class='fas fa-plus'></i>
      </a>
    </div>
  </li>
  {{#each features as |item id|}}
    <li class='item' data-item-id='{{item._id}}'>
      <div class='item-header flexrow'>
        <div class='item-name'>
          <div class='item-image'>
            <a class='rollable' data-roll-type='item'>
              <img
                src='{{item.img}}'
                title='{{item.name}}'
                width='24'
                height='24'
              />
            </a>
          </div>
          <h4 class='item-name-toggle' style='cursor: pointer;'>
            <i class='fas fa-chevron-right item-toggle-icon' style='font-size: 0.7em; margin-right: 5px; transition: transform 0.2s;'></i>
            {{item.name}}
          </h4>
        </div>
        <div class='item-controls'>
          <a
            class='item-control item-edit'
            title='{{localize "DOCUMENT.Edit" type='feature'}}'
          >
            <i class='fas fa-edit'></i>
          </a>
          <a
            class='item-control item-delete'
            title='{{localize "DOCUMENT.Delete" type='feature'}}'
          >
            <i class='fas fa-trash'></i>
          </a>
        </div>
      </div>
      <div class='item-description' style='display: none; padding: 8px 8px 8px 40px; border-top: 1px solid rgba(0,0,0,0.1); background: rgba(0,0,0,0.05);'>
        {{{item.system.description}}}
      </div>
    </li>
  {{/each}}
</ol>