<ol class="items-list">
  <li class="item flexrow inventory-header">
    <div class="item-controls" style="flex: 0 0 auto; margin-left: auto;">
      <a class="item-control item-create" title="Create item" data-type="item"><i class="fas fa-plus"></i></a>
    </div>
  </li>

  {{!-- 일반 물건 섹션 --}}
  {{#if itemsByType.general.length}}
  <li class="item flexrow items-header">
    <div class="item-name">{{localize 'RAVE.SheetLabels.TypeGeneral'}}</div>
  </li>
  {{#each itemsByType.general as |item id|}}
    <li class="item" data-item-id="{{item._id}}">
      <div class="item-header flexrow">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item">
              <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
            </a>
          </div>
          <h4 class="item-name-header item-name-toggle" style="cursor: pointer;">
            <i class="fas fa-chevron-right item-toggle-icon" style="font-size: 0.7em; margin-right: 5px; transition: transform 0.2s;"></i>
            {{item.name}}
          </h4>
        </div>
        <div class="item-quantity" style="flex: 0 0 50px; text-align: center;">{{item.system.quantity}}개</div>
        <div class="item-weight" style="flex: 0 0 60px; text-align: center;">{{item.system.weight}}칸</div>
        <div class="item-controls">
          <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
        </div>
      </div>
      <div class="item-description" style="display: none; padding: 8px 8px 8px 40px; border-top: 1px solid rgba(0,0,0,0.1); background: rgba(0,0,0,0.05);">
        {{{item.system.description}}}
      </div>
    </li>
  {{/each}}
  {{/if}}

  {{!-- 무기 섹션 --}}
  {{#if itemsByType.weapon.length}}
  <li class="item flexrow items-header" style="margin-top: 10px;">
    <div class="item-name">{{localize 'RAVE.SheetLabels.TypeWeapon'}}</div>
  </li>
  {{#each itemsByType.weapon as |item id|}}
    <li class="item" data-item-id="{{item._id}}">
      <div class="item-header flexrow">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item">
              <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
            </a>
          </div>
          <h4 class="item-name-header item-name-toggle" style="cursor: pointer;">
            <i class="fas fa-chevron-right item-toggle-icon" style="font-size: 0.7em; margin-right: 5px; transition: transform 0.2s;"></i>
            {{item.name}}
          </h4>
        </div>
        <div class="item-formula" style="flex: 0 0 80px; text-align: center;">{{item.system.formula}}</div>
        <div class="item-quantity" style="flex: 0 0 50px; text-align: center;">{{item.system.quantity}}개</div>
        <div class="item-weight" style="flex: 0 0 60px; text-align: center;">{{item.system.weight}}칸</div>
        <div class="item-controls">
          <a class="item-control weapon-attack-button" data-item-id="{{item._id}}" title="{{localize 'RAVE.SheetLabels.Attack'}}">
            <i class="fas fa-dice-d20"></i>
          </a>
          <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
        </div>
      </div>
      <div class="item-description" style="display: none; padding: 8px 8px 8px 40px; border-top: 1px solid rgba(0,0,0,0.1); background: rgba(0,0,0,0.05);">
        {{{item.system.description}}}
      </div>
    </li>
  {{/each}}
  {{/if}}

  {{!-- 주문 섹션 --}}
  {{#if itemsByType.spell.length}}
  <li class="item flexrow items-header" style="margin-top: 10px;">
    <div class="item-name">{{localize 'RAVE.SheetLabels.TypeSpell'}}</div>
  </li>
  {{#each itemsByType.spell as |item id|}}
    <li class="item" data-item-id="{{item._id}}">
      <div class="item-header flexrow">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item">
              <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
            </a>
          </div>
          <h4 class="item-name-header item-name-toggle" style="cursor: pointer;">
            <i class="fas fa-chevron-right item-toggle-icon" style="font-size: 0.7em; margin-right: 5px; transition: transform 0.2s;"></i>
            {{item.name}}
          </h4>
        </div>
        <div class="item-formula" style="flex: 0 0 80px; text-align: center;">{{item.system.formula}}</div>
        <div class="item-quantity" style="flex: 0 0 50px; text-align: center;">{{item.system.quantity}}개</div>
        <div class="item-weight" style="flex: 0 0 60px; text-align: center;">{{item.system.weight}}칸</div>
        <div class="item-controls">
          <a class="item-control spell-cast-button" data-item-id="{{item._id}}" title="{{localize 'RAVE.SheetLabels.CastSpell'}}">
            <i class="fas fa-magic"></i>
          </a>
          <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
        </div>
      </div>
      <div class="item-description" style="display: none; padding: 8px 8px 8px 40px; border-top: 1px solid rgba(0,0,0,0.1); background: rgba(0,0,0,0.05);">
        {{{item.system.description}}}
      </div>
    </li>
  {{/each}}
  {{/if}}

  {{!-- 신비 섹션 --}}
  {{#if itemsByType.mystery.length}}
  <li class="item flexrow items-header" style="margin-top: 10px;">
    <div class="item-name">{{localize 'RAVE.SheetLabels.TypeMystery'}}</div>
  </li>
  {{#each itemsByType.mystery as |item id|}}
    <li class="item" data-item-id="{{item._id}}">
      <div class="item-header flexrow">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item">
              <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
            </a>
          </div>
          <h4 class="item-name-header item-name-toggle" style="cursor: pointer;">
            <i class="fas fa-chevron-right item-toggle-icon" style="font-size: 0.7em; margin-right: 5px; transition: transform 0.2s;"></i>
            {{item.name}}
          </h4>
        </div>
        <div class="item-quantity" style="flex: 0 0 50px; text-align: center;">{{item.system.quantity}}개</div>
        <div class="item-weight" style="flex: 0 0 60px; text-align: center;">{{item.system.weight}}칸</div>
        <div class="item-controls">
          <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
        </div>
      </div>
      <div class="item-description" style="display: none; padding: 8px 8px 8px 40px; border-top: 1px solid rgba(0,0,0,0.1); background: rgba(0,0,0,0.05);">
        {{{item.system.description}}}
      </div>
    </li>
  {{/each}}
  {{/if}}

  {{!-- 방어구 섹션 --}}
  {{#if itemsByType.armor.length}}
  <li class="item flexrow items-header" style="margin-top: 10px;">
    <div class="item-name">{{localize 'RAVE.SheetLabels.TypeArmor'}}</div>
  </li>
  {{#each itemsByType.armor as |item id|}}
    <li class="item" data-item-id="{{item._id}}">
      <div class="item-header flexrow">
        <div class="item-name">
          <div class="item-image">
            <a class="rollable" data-roll-type="item">
              <img src="{{item.img}}" title="{{item.name}}" width="24" height="24"/>
            </a>
          </div>
          <div class="armor-info">
            <h4 class="item-name-header item-name-toggle" style="cursor: pointer;">
              <i class="fas fa-chevron-right item-toggle-icon" style="font-size: 0.7em; margin-right: 5px; transition: transform 0.2s;"></i>
              {{item.name}}
            </h4>
            {{#if item.system.isCumbersome}}<span style="font-size: 0.8em; color: #c9c7b8;">(불편함)</span>{{/if}}
            {{#if item.system.isAccessory}}<span style="font-size: 0.8em; color: #c9c7b8;">(부속)</span>{{/if}}
          </div>
        </div>
        <div class="item-formula" style="flex: 0 0 80px; text-align: center;">+{{item.system.acBonus}}</div>
        <div class="item-quantity" style="flex: 0 0 50px; text-align: center;">{{item.system.quantity}}개</div>
        <div class="item-weight" style="flex: 0 0 60px; text-align: center;">{{item.system.weight}}칸</div>
        <div class="item-controls">
          <a class="item-control item-edit" title="Edit Item"><i class="fas fa-edit"></i></a>
          <a class="item-control item-delete" title="Delete Item"><i class="fas fa-trash"></i></a>
        </div>
      </div>
      <div class="item-description" style="display: none; padding: 8px 8px 8px 40px; border-top: 1px solid rgba(0,0,0,0.1); background: rgba(0,0,0,0.05);">
        {{{item.system.description}}}
      </div>
    </li>
  {{/each}}
  {{/if}}
</ol>
