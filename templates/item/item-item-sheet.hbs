<form class="{{cssClass}}" autocomplete="off">
  <header class="sheet-header">
    <img class="profile-img" src="{{item.img}}" data-edit="img" title="{{item.name}}" />
    <div class="header-fields">
      <h1 class="charname"><input name="name" type="text" value="{{item.name}}" placeholder="이름" /></h1>
      <div class="grid grid-3col">
        <div class="resource">
          <label class="resource-label">수량</label>
          <input type="text" name="system.quantity" value="{{system.quantity}}" data-dtype="Number" />
        </div>
        <div class="resource">
          <label class="resource-label">물건 칸</label>
          <input type="text" name="system.weight" value="{{system.weight}}" data-dtype="Number" />
        </div>
        <div class="resource">
          <label class="resource-label">{{localize "RAVE.SheetLabels.Price"}}</label>
          <input type="text" name="system.price" value="{{system.price}}" data-dtype="Number" />
        </div>
        <div class="resource">
          <label class="resource-label">{{localize "RAVE.SheetLabels.ItemType"}}</label>
          <select name="system.itemType" style="height: 28px;">
            <option value="general" {{#if (eq system.itemType "general")}}selected{{/if}}>{{localize "RAVE.SheetLabels.TypeGeneral"}}</option>
            <option value="weapon" {{#if (eq system.itemType "weapon")}}selected{{/if}}>{{localize "RAVE.SheetLabels.TypeWeapon"}}</option>
            <option value="spell" {{#if (eq system.itemType "spell")}}selected{{/if}}>{{localize "RAVE.SheetLabels.TypeSpell"}}</option>
            <option value="mystery" {{#if (eq system.itemType "mystery")}}selected{{/if}}>{{localize "RAVE.SheetLabels.TypeMystery"}}</option>
            <option value="armor" {{#if (eq system.itemType "armor")}}selected{{/if}}>{{localize "RAVE.SheetLabels.TypeArmor"}}</option>
          </select>
        </div>
      </div>
    </div>
  </header>

  <nav class="sheet-tabs tabs" data-group="primary">
    <a class="item" data-tab="description">설명</a>
    <a class="item" data-tab="attributes">속성</a>
  </nav>

  <section class="sheet-body">
    <div class="tab" data-group="primary" data-tab="description">
      {{editor system.description target="system.description" rollData=rollData button=true owner=owner editable=editable}}
    </div>
    
    <div class="tab attributes" data-group="primary" data-tab="attributes">
      
      {{!-- 무기일 때만 공격 능력치 선택 표시 --}}
      {{#if (eq system.itemType "weapon")}}
      <div class="form-group">
        <label>{{localize "RAVE.SheetLabels.AttackAbility"}}</label>
        <select name="system.ability">
          <option value="str" {{#if (eq system.ability "str")}}selected{{/if}}>{{localize "RAVE.Ability.Str.long"}}</option>
          <option value="dex" {{#if (eq system.ability "dex")}}selected{{/if}}>{{localize "RAVE.Ability.Dex.long"}}</option>
          <option value="wis" {{#if (eq system.ability "wis")}}selected{{/if}}>{{localize "RAVE.Ability.Wis.long"}}</option>
          <option value="wil" {{#if (eq system.ability "wil")}}selected{{/if}}>{{localize "RAVE.Ability.Wil.long"}}</option>
        </select>
      </div>
      {{/if}}

      {{!-- 주문일 때만 주문 레벨 표시 --}}
      {{#if (eq system.itemType "spell")}}
      <div class="resource">
        <label class="resource-label">{{localize "RAVE.SheetLabels.SpellLevel"}}</label>
        <input type="text" name="system.spellLevel" value="{{system.spellLevel}}" data-dtype="Number" placeholder="0"/>
      </div>
      {{/if}}

      {{!-- 방어구일 때만 AC 보너스 표시 --}}
      {{#if (eq system.itemType "armor")}}
      <div class="resource">
        <label class="resource-label">{{localize "RAVE.SheetLabels.ArmorBonus"}}</label>
        <input type="text" name="system.acBonus" value="{{system.acBonus}}" data-dtype="Number" placeholder="0"/>
      </div>
      <div class="form-group">
        <label>
          <input type="checkbox" name="system.isCumbersome" {{#if system.isCumbersome}}checked{{/if}} />
          {{localize "RAVE.SheetLabels.Cumbersome"}} (재주 보너스 불가)
        </label>
      </div>
      <div class="form-group">
        <label>
          <input type="checkbox" name="system.isAccessory" {{#if system.isAccessory}}checked{{/if}} />
          {{localize "RAVE.SheetLabels.Accessory"}} (여러 개 입기 가능)
        </label>
      </div>
      {{/if}}

      {{!-- 무기일 때만 주사위 필드 표시 --}}
      {{#if (eq system.itemType "weapon")}}
      <div class="resource">
        <label class="resource-label">{{localize "RAVE.SheetLabels.DiceFormula"}}</label>
        <input type="text" name="system.formula" value="{{system.formula}}" data-dtype="String" placeholder="예: 1d6"/>
      </div>
      {{/if}}
    </div>
  </section>
</form>